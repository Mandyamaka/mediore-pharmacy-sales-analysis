<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="MediCore_Pharmacy_SQL.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2323"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="pharmacy_sales" custom_title="0" dock_id="6" table="4,14:mainpharmacy_sales"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="pharmacy_sales" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="85"/><column index="2" value="39"/><column index="3" value="44"/><column index="4" value="29"/><column index="5" value="109"/><column index="6" value="101"/><column index="7" value="93"/><column index="8" value="101"/><column index="9" value="68"/><column index="10" value="66"/><column index="11" value="65"/><column index="12" value="71"/><column index="13" value="138"/><column index="14" value="66"/><column index="15" value="78"/><column index="16" value="50"/><column index="17" value="82"/><column index="18" value="84"/><column index="19" value="79"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT *
FROM pharmacy_sales;

-- Total revenue
SELECT SUM(revenue) AS total_revenue
FROM pharmacy_sales;

-- Revenue by region
SELECT region, SUM(revenue) AS total_revenue
FROM pharmacy_sales
GROUP BY region;

-- Top medicine
SELECT medicine, SUM(revenue) AS total_revenue
FROM pharmacy_sales
GROUP BY medicine
ORDER BY total_revenue DESC;

-- Revenue by year
SELECT year, SUM(revenue) AS total_revenue
FROM pharmacy_sales
GROUP BY year;

-- COVID VS NON-COVID 
SELECT covid_flag, SUM(revenue)  AS total_revenue
FROM pharmacy_sales
GROUP BY covid_flag;

-- Revenue by category
SELECT category, SUM(revenue) AS total_revenue
FROM pharmacy_sales
GROUP BY category
ORDER BY total_revenue DESC;

-- Revenue by Country 
SELECT country, SUM(revenue) AS total_revenue
FROM pharmacy_sales
GROUP BY country
ORDER BY total_revenue DESC;

-- Revenue by age group
SELECT age_group, SUM(revenue) AS total_revenue
FROM pharmacy_sales
GROUP BY age_group
ORDER BY total_revenue DESC; 

-- Low stock medicines
SELECT medicine, region, stock_level
FROM pharmacy_sales
WHERE stock_level &lt; 2000
ORDER BY stock_level ASC;

-- Medicines nearing Expiry 
SELECT medicine, region, expiry_days_remaining
FROM pharmacy_sales
WHERE expiry_days_remaining &lt; 90
ORDER BY expiry_days_remaining ASC;

-- Average unit price by Category 
SELECT category, AVG(unit_price) AS avg_unit_price
FROM pharmacy_sales
GROUP BY category
ORDER BY avg_unit_price DESC;

-- Top selling medicines by Units sold
SELECT medicine, SUM(units_sold) AS total_units_sold
FROM pharmacy_sales
GROUP BY medicine
ORDER BY total_units_sold DESC
LIMIT 10;

-- Yearly Growth
WITH yearly_revenue AS (
    SELECT 
        year,
        SUM(revenue) AS total_revenue
    FROM pharmacy_sales
    GROUP BY year
)
SELECT year, total_revenue,
    LAG(total_revenue) OVER (ORDER BY year) AS prev_year_revenue,
    ROUND(
        ((total_revenue - LAG(total_revenue) OVER (ORDER BY year)) 
        / LAG(total_revenue) OVER (ORDER BY year)) * 100, 
    2) AS yearly_growth_percentage
FROM yearly_revenue;

-- Monthly revenue trend
SELECT year, month, SUM(revenue) AS monthly_revenue
FROM pharmacy_sales
GROUP BY year, month
ORDER BY year, month;

SELECT month, SUM(revenue) AS monthly_revenue
FROM pharmacy_sales
GROUP BY month
ORDER BY month;</sql><current_tab id="0"/></tab_sql></sqlb_project>
